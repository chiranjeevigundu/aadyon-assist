# Development environment template — copy to .env on your local dev machine:
#   cp .env.development.example .env
# (or run `just bootstrap-dev`, which does this plus generates secrets/*.txt).
# .env is gitignored; this file documents dev-appropriate defaults only.

# Postgres
POSTGRES_USER=aadyon
POSTGRES_DB=aadyon_assist
# DB password is provided via Docker secret (see secrets/db_password.txt), not here.

# API
API_PORT=8000
TZ=UTC

# --- Auth (multi-user) ---
# Signing key for JWT bearer tokens. REQUIRED for login/signup. Prefer the Docker
# secret secrets/jwt_secret.txt; this env var is the fallback. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Short-lived in dev is fine; shorten further if you're testing token expiry.
JWT_EXPIRE_MINUTES=43200

# --- Agentic layer (model routing) ---
# Needed to exercise the assistant/agency chat locally. Get a key at openrouter.ai.
# Prefer the Docker secret secrets/openrouter_api_key.txt; this env var is the fallback.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Local models via Ollama on the host (install + `ollama serve`). From containers,
# the host is reachable as host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
AGENCY_WORKER_ENABLED=true
AGENT_MAX_STEPS=6

# --- Push notifications (self-hosted ntfy) ---
# `just up-dev` doesn't start ntfy/backup by default (dev doesn't need push or
# scheduled backups of throwaway data) — leave blank unless you're testing alerts.
ALERT_DAYS=3
NTFY_TOPIC=
NTFY_PORT=8090
NTFY_BASE_URL=http://localhost:8090

# --- Document/file storage ---
# local  (default): persist uploads under artifacts_dir/uploads on this host.
# s3     : S3-compatible object storage (set S3_* below) — the cloud/multi-instance option.
# mock   : no real I/O (tests only).
STORAGE_BACKEND=local

# --- Email ingest --- (optional; leave blank unless testing the connector)
EMAIL_ENC_KEY=
EMAIL_LOOKBACK_DAYS=14
EMAIL_MAX_MESSAGES=40
MS_CLIENT_ID=
MS_TENANT=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

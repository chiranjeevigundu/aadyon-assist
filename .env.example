# Copy to .env and fill in. .env is gitignored.
# Postgres
POSTGRES_USER=aadyon
POSTGRES_DB=aadyon_assist
# DB password is provided via Docker secret (see secrets/db_password.txt), not here.

# API
API_PORT=8000
# Connection string is assembled by the api service from the secret + the values above.
TZ=America/Phoenix

# --- Auth (multi-user) ---
# Signing key for JWT bearer tokens. REQUIRED for login/signup. Prefer the Docker
# secret secrets/jwt_secret.txt; this env var is the fallback. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# How long a login stays valid (minutes). Default 30 days for mobile clients.
JWT_EXPIRE_MINUTES=43200

# --- Agentic layer (model routing) ---
# OpenRouter connects to many providers (and an auto-router). Get a key at openrouter.ai.
# Prefer the Docker secret secrets/openrouter_api_key.txt; this env var is the fallback.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Local models via Ollama on the host (install + `ollama serve`). From containers,
# the host is reachable as host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Background worker that drains the agent task queue.
AGENCY_WORKER_ENABLED=true
AGENT_MAX_STEPS=6

# --- Push notifications (self-hosted ntfy) ---
# Set NTFY_TOPIC to a private, hard-to-guess string to enable the morning push.
# Leave blank to disable. The phone subscribes to this topic on your ntfy server.
NTFY_TOPIC=
# Port the ntfy server is published on (phone reaches it at NTFY_BASE_URL).
NTFY_PORT=8090
# The URL your phone uses to reach the ntfy server (your Tailscale address + port).
NTFY_BASE_URL=http://your-ntfy-host:8090

# --- Email ingest ---
# Fernet key used to encrypt stored email app-passwords. REQUIRED to connect a mailbox.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENC_KEY=
EMAIL_LOOKBACK_DAYS=14
EMAIL_MAX_MESSAGES=40

# Microsoft Graph (Outlook / Microsoft 365) — device-code OAuth.
# Register a free Azure app (public client, "Allow public client flows" = yes,
# delegated Graph permission Mail.Read + offline_access), then paste its
# Application (client) ID here. MS_TENANT: 'common' (any), 'organizations', or your tenant id.
MS_CLIENT_ID=
MS_TENANT=common

# Gmail OAuth (added in the Gmail pass).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

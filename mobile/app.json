{
  "expo": {
    "name": "Aadyon Assist",
    "slug": "aadyon-assist",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aadyon",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0b0f17",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.aadyon.assist",
      "buildNumber": "4",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow Aadyon Assist to access the microphone for voice commands",
        "NSSpeechRecognitionUsageDescription": "Allow Aadyon Assist to recognize your speech"
      }
    },
    "android": {
      "package": "me.aadyon.assist",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Aadyon Assist to access the microphone for voice commands",
          "speechRecognitionPermission": "Allow Aadyon Assist to recognize your speech"
        }
      ]
    ],
    "extra": {
      "defaultApiBase": "http://localhost:8000",
      "eas": {
        "projectId": "b8415cd5-c5eb-4c55-b4ee-7e465fbc41a2"
      }
    },
    "owner": "aadyon-assist"
  }
}

{
  "expo": {
    "name": "Aadyon Assist",
    "slug": "aadyon-assist",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aadyon",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0b0f17",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.aadyon.assist",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "The assistant uses the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Speech is transcribed on-device to text you send to your assistant."
      }
    },
    "android": {
      "package": "me.aadyon.assist"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Aadyon Assist to access the microphone for voice commands",
          "speechRecognitionPermission": "Allow Aadyon Assist to recognize your speech"
        }
      ]
    ],
    "extra": {
      "defaultApiBase": "http://localhost:8000"
    },
    "plugins": [
      "expo-speech-recognition"
    ]
  }
}
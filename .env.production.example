# Production environment template — copy to .env on the always-on server (Mac Mini):
#   cp .env.production.example .env
# (or run `just bootstrap-prod`, which does this plus generates secrets/*.txt).
# .env is gitignored; this file documents prod-appropriate defaults only. If a
# production .env already exists, this file does NOT replace it — it's only a
# from-scratch template for standing up a fresh prod instance.

# Postgres
POSTGRES_USER=aadyon
POSTGRES_DB=aadyon_assist
# DB password is provided via Docker secret (see secrets/db_password.txt), not here.

# API
API_PORT=8000
# Set to your actual timezone so BRIEFING_HOUR / alert digests land at the right time.
TZ=America/Phoenix

# --- Auth (multi-user) ---
# Signing key for JWT bearer tokens. REQUIRED for login/signup. Prefer the Docker
# secret secrets/jwt_secret.txt; this env var is the fallback. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRE_MINUTES=43200

# --- Agentic layer (model routing) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434
AGENCY_WORKER_ENABLED=true
AGENT_MAX_STEPS=6

# --- Push notifications (self-hosted ntfy) ---
# Set NTFY_TOPIC to a private, hard-to-guess string to enable the morning push.
ALERT_DAYS=3
NTFY_TOPIC=
NTFY_PORT=8090
# Your Tailscale hostname/IP + NTFY_PORT — this is what the phone actually reaches.
NTFY_BASE_URL=http://your-tailscale-host:8090

# --- Document/file storage ---
# local (default): persist uploads under artifacts_dir/uploads (fine for the single
#   Mac Mini host). s3: S3-compatible object storage — switch to this when moving to
#   a cloud platform / running more than one API instance (set S3_* + the s3 secrets).
# mock: no real I/O (tests only) — never use in production.
STORAGE_BACKEND=local

# --- Email ingest ---
# Fernet key used to encrypt stored email app-passwords. REQUIRED to connect a mailbox.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENC_KEY=
EMAIL_LOOKBACK_DAYS=14
EMAIL_MAX_MESSAGES=40
MS_CLIENT_ID=
MS_TENANT=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
